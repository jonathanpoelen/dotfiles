default partial alphanumeric_keys modifier_keys
xkb_symbols "jln" {

include "us(altgr-intl)"
name[Group1]= "English (intl., Jln)";

// Compose key on Pause
key <PAUS> { [ Multi_key ] };
// Compose key on Scroll Lock
key <SCLK> { [ Multi_key ] };

// swap numbers/symbols
key <AE01> { [ percent, 1, onesuperior, onehalf ] };
key <AE02> { [ numbersign, 2, twosuperior, threequarters ] };
key <AE03> { [ ampersand, 3, threesuperior, onequarter ] };
key <AE04> { [ exclam, 4, egrave, Egrave ] };
key <AE05> { [ dollar, 5, EuroSign, currency ] };
key <AE06> { [ dead_circumflex, 6, asciicircum, exclamdown ] };
key <AE07> { [ at, 7, degree, dead_horn ] };
key <AE08> { [ asterisk, 8, dead_ogonek, threequarters ] };
key <AE09> { [ underscore, 9, parenleft, leftsinglequotemark ] };
key <AE10> { [ parenleft, 0, parenright, rightsinglequotemark ] };
key <AE11> { [ parenright, minus, underscore, yen ] };

// Backslash / bar remap with variants
key <BKSL> { [ backslash, bar, ampersand, brokenbar ] };
key <LSGT> { [ bar, ampersand, backslash, notsign ] };

// AltGr + r = ê
key <AD04> { [ r, R, ecircumflex, Ecircumflex ] };
